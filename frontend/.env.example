# ─────────────────────────────────────────────────────────
# MCNE Visualizer (Frontend) - Environment Variables Template
# ─────────────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.local`) to override the defaults.
# All variables are optional; the values below match the backend defaults,
# so the Visualizer works out of the box against a local backend.
# ─────────────────────────────────────────────────────────

# Backend REST base URL
VITE_API_URL=http://localhost:8081

# Backend WebSocket (STOMP) URL
VITE_WS_URL=ws://localhost:8081/ws-mcne

# API key sent via the X-API-Key header. Must match the backend MCNE_API_KEY.
VITE_API_KEY=dev-only-key

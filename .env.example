# ─────────────────────────────────────────────────────────
# MCNE — Environment Variables Template
# ─────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# The `.env` file is listed in .gitignore and must NEVER be committed.
#
# Usage: Docker Compose reads `.env` automatically from the project root.
# ─────────────────────────────────────────────────────────

# PostgreSQL
DB_USERNAME=mcne_user
DB_PASSWORD=change_me
DB_NAME=mcne_db

# AWS Credentials (required for Email / SMS delivery)
AWS_REGION=us-east-2
AWS_ACCESS_KEY=your-access-key-here
AWS_SECRET_KEY=your-secret-key-here
AWS_VERIFIED_EMAIL=no-reply@yourdomain.com

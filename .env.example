# ─────────────────────────────────────────────────────────
# MCNE — Environment Variables Template
# ─────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# The `.env` file is listed in .gitignore and must NEVER be committed.
#
# Usage: Docker Compose reads `.env` automatically from the project root.
# ─────────────────────────────────────────────────────────

# PostgreSQL
DB_USERNAME=mcne_user
DB_PASSWORD=change_me
DB_NAME=mcne_db

# AWS Credentials (required for Email / SMS delivery)
# Leave blank to use DefaultCredentialsProvider (IAM role / instance profile).
AWS_REGION=us-east-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_VERIFIED_EMAIL=no-reply@yourdomain.com

# Security — API key required on all /api/** endpoints via X-API-Key header.
# Change this to a strong random value before exposing the service publicly.
MCNE_API_KEY=dev-only-key

# CORS — comma-separated list of allowed frontend origins.
# Example for production: https://your-frontend.example.com
MCNE_ALLOWED_ORIGINS=http://localhost:5173

# RabbitMQ (optional, defaults to guest/guest for local dev)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
